{
  "name": "ortho-tracker",
  "version": "2.0.0",
  "description": "Orthodontic patient management desktop application",
  "author": " Dr Sukrit Thakur",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "fs-extra": "^11.2.0",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.2"
  },
  "build": {
    "appId": "com.orthotracker",
    "productName": "OrthoTracker",
    "directories": { "output": "dist" },
    "win": { "icon": "resources/icon.png", "target": ["nsis"] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "shortcutName": "OrthoTracker" }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}